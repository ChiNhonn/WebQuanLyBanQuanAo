@model IEnumerable<DoAnMonWeb.Models.ChiTietDonHang>
@{
    var dh = ViewBag.DonHang as DoAnMonWeb.Models.DonHang;
}

<div class="container mt-4" style="border: 1px solid #000; padding: 30px; border-radius: 20px;">
    <div class="d-flex justify-content-between align-items-center border-bottom pb-3">
        <h3>Chi tiết đơn hàng #@dh.MaDonHang</h3>
        <span class="badge bg-dark p-2">@dh.TrangThai</span>
    </div>

    <div class="row mt-4">
        <div class="col-md-6">
            <p><strong>Ngày đặt:</strong> @dh.NgayDat?.ToString("dd/MM/yyyy HH:mm")</p>
            <p><strong>Thanh toán:</strong> @dh.PhuongThucThanhToan</p>
        </div>
        <div class="col-md-6 text-end">
            <h4 class="text-danger">Tổng tiền: @dh.TongTien.ToString("N0") đ</h4>
        </div>
    </div>

    <table class="table mt-4">
        <thead class="table-light">
            <tr>
                <th>Sản phẩm</th>
                <th>Đơn giá</th>
                <th>Số lượng</th>
                <th>Thành tiền</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td style="display: flex; align-items: center; gap: 15px;">
                        <img src="~/images/QuanAo/@item.SanPham?.HinhAnh" width="60" style="border-radius: 8px;" />
                        <span>@item.SanPham?.TenSP</span>
                    </td>
                    <td>@item.Gia.ToString("N0") đ</td>
                    <td>@item.SoLuong</td>
                    <td>@((item.Gia * item.SoLuong).ToString("N0")) đ</td>
                </tr>
            }
        </tbody>
    </table>

    <div class="mt-4">
        <a href="@Url.Action("DashboardLogin", "TaiKhoan")" class="btn btn-outline-dark">
            <i class="fas fa-arrow-left"></i> Quay lại
        </a>
    </div>
</div>