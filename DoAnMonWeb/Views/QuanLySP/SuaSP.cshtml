@model DoAnMonWeb.Models.SanPham

@{
    Layout = "_Layout";
    ViewData["Title"] = "Sửa sản phẩm";
}

<link href="~/css/quanlysp.css" rel="stylesheet" />

<div class="form-container">
    <h2 class="title">Sửa sản phẩm</h2>

    <form asp-controller="QuanLySP" asp-action="SuaSP" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="MaSP" />

        <div class="form-group">
            <label>Tên sản phẩm</label>
            <input asp-for="TenSP" class="form-control" />
            <span class="text-danger">@Html.ValidationMessageFor(m => m.TenSP)</span>
        </div>

        <div class="form-group">
            <label>Giá</label>
            <input asp-for="Gia" type="number" class="form-control" />
            <span class="text-danger">@Html.ValidationMessageFor(m => m.Gia)</span>
        </div>

        <div class="form-group">
            <label>Mô tả</label>
            <textarea asp-for="MoTa" class="form-control"></textarea>
            <span class="text-danger">@Html.ValidationMessageFor(m => m.MoTa)</span>
        </div>

        <div class="form-group">
            <label>Mã loại</label>
            <select asp-for="MaLoai" class="form-control">
                <option value="">-- Chọn loại sản phẩm --</option>

                @if (ViewBag.LoaiList != null)
                {
                    foreach (var loai in ViewBag.LoaiList)
                    {
                        <option value="@loai.MaLoai">(@loai.MaLoai)@loai.TenLoai</option>
                    }
                }
            </select>       
            <span class="text-danger">@Html.ValidationMessageFor(m => m.MaLoai)</span>
        </div>

        <div class="form-group">
            <label>Hình ảnh hiện tại</label><br />
            @if (!string.IsNullOrEmpty(Model.HinhAnh))
            {
                <img src="~/images/QuanAo/@Model.HinhAnh" width="120" />
            }
        </div>

        <div class="form-group">
            <label>Chọn ảnh mới (nếu muốn thay)</label>
            <input type="file" name="file" class="form-control" />
            <span class="text-danger">@Html.ValidationMessageFor(m => m.HinhAnh)</span>
        </div>

        <div class="btn-group">
            <button type="submit" class="btn btn-primary">Cập nhật</button>
            <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
        </div>

    </form>
</div>