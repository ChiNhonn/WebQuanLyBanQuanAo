@model DoAnMonWeb.Models.LoaiSanPham

<h2>Thêm loại sản phẩm</h2>

<form asp-controller="QuanLyLSP" asp-action="ThemLSP" method="post" enctype="multipart/form-data">
    <div>
        <label>Tên loại</label>
        <input asp-for="TenLoai" class="form-control" />
        <span class="text-danger">@Html.ValidationMessageFor(m => m.TenLoai)</span>
    </div>

    <button type="submit" class="btn btn-success">Thêm</button>
    <a asp-controller="QuanLyLSP" asp-action="Index" class="btn btn-secondary">
        Quay lại
    </a>
</form>