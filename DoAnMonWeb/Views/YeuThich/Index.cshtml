@model List<DoAnMonWeb.Models.YeuThichItem>
@if(TempData["Success"] != null)
{
    <div class="alert-success">
        @TempData["Success"]
    </div>
}
@{
    Layout = "_Layout";
    ViewData["Title"] = "Sản phẩm yêu thích";
}
<link rel="stylesheet" href="~/css/yeuthich.css" />

<section class="wishlist-container">
    <h2 class="header-yeuthich">Sản phẩm bạn yêu thích</h2>
    <div class="line-deco"></div>

    @if (Model.Count == 0)
    {
        <div class="empty-wishlist">
            <p>Danh sách yêu thích của bạn đang trống.</p>
            <a asp-controller="SanPham" asp-action="Index" class="btn-continue">Tiếp tục mua sắm</a>
        </div>
    }
    else
    {
        <div class="wishlist-grid">
            @foreach (var item in Model)
            {
                <div class="wishlist-item">
                    <div class="wishlist-img">
                        <img src="~/images/quanao/@item.HinhAnh" alt="@item.TenSP" />
                        <a href="@Url.Action("XoaYeuThich", "YeuThich", new { id = item.MaSP })" class="btn-remove-wishlist">×</a>
                    </div>
                    <div class="wishlist-info">
                        <h4 class="h4 wishlist-info">@item.TenSP</h4>
                        <p>@item.Gia.ToString("N0")đ</p>
                        <a href="@Url.Action("ThemGioHang", "GioHang", new { id = item.MaSP, size = item.size})" class="btn-add-to-cart">
                            Thêm vào giỏ hàng
                        </a>
                    </div>
                </div>
            }
        </div>
    }
</section>