@model DoAnMonWeb.Models.MauSac

<h2>Thêm màu sắc</h2>

<form asp-controller="QuanLyMauSac" asp-action="ThemMS" method="post">
    <div>
        <label>Tên màu</label>
        <input asp-for="TenMauSac" class="form-control" />
    </div>

    <button type="submit" class="btn btn-success">Thêm</button>
    <a asp-controller="QuanLySP" asp-action="Index" class="btn btn-secondary">Quay lại</a>
</form>