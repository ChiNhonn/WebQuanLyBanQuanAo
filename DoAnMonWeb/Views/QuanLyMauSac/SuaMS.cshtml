@model DoAnMonWeb.Models.MauSac

<h2>Sửa màu sắc</h2>

<form asp-controller="QuanLyMauSac" asp-action="SuaMS" method="post">
    <input type="hidden" asp-for="MaMauSac" />
    <div>
        <label>Tên màu</label>
        <input asp-for="TenMauSac" class="form-control" />
    </div>
    <button type="submit" class="btn btn-primary">Cập nhật</button>
    <a asp-controller="QuanLySP" asp-action="Index" class="btn btn-secondary">Quay lại</a>

</form>s